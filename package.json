{
  "name": "openpet",
  "version": "1.0.1-rc.3",
  "description": "OpenPet Electron desktop pet platform with Control Center, AI, plugins, and local APIs.",
  "author": "OpenPet contributors",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/cleanup-dev-instances.js && npm run build:control-center && electron .",
    "dev:control-center": "vite --config src/control-center/vite.config.js --host 127.0.0.1",
    "build:control-center": "vite build --config src/control-center/vite.config.js",
    "pack": "npm run build:control-center && electron-builder --dir",
    "dist": "npm run build:control-center && electron-builder",
    "generate-icons": "node scripts/generate-icons.js",
    "prepare-windows-release-assets": "node scripts/prepare-windows-release-assets.js",
    "create-windows-smoke-report": "node scripts/create-windows-smoke-report.js",
    "create-windows-smoke-runbook": "node scripts/create-windows-smoke-runbook.js",
    "create-windows-smoke-collector": "node scripts/create-windows-smoke-collector.js",
    "create-windows-smoke-evidence-summary": "node scripts/create-windows-smoke-evidence-summary.js",
    "create-windows-smoke-archive-manifest": "node scripts/create-windows-smoke-archive-manifest.js",
    "update-windows-smoke-report": "node scripts/update-windows-smoke-report.js",
    "validate-windows-smoke-report": "node scripts/validate-windows-smoke-report.js",
    "validate-windows-smoke-evidence-bundle": "node scripts/validate-windows-smoke-evidence-bundle.js",
    "create-desktop-picker-smoke-report": "node scripts/create-desktop-picker-smoke-report.js",
    "create-desktop-picker-smoke-runbook": "node scripts/create-desktop-picker-smoke-runbook.js",
    "create-desktop-picker-evidence-summary": "node scripts/create-desktop-picker-evidence-summary.js",
    "create-desktop-picker-archive-manifest": "node scripts/create-desktop-picker-archive-manifest.js",
    "update-desktop-picker-smoke-report": "node scripts/update-desktop-picker-smoke-report.js",
    "validate-desktop-picker-smoke-report": "node scripts/validate-desktop-picker-smoke-report.js",
    "create-packaged-runtime-smoke-report": "node scripts/create-packaged-runtime-smoke-report.js",
    "create-packaged-runtime-smoke-runbook": "node scripts/create-packaged-runtime-smoke-runbook.js",
    "run-packaged-runtime-smoke": "node scripts/run-packaged-runtime-smoke.js",
    "run-ai-talk-local-smoke": "node scripts/run-ai-talk-local-smoke.js",
    "create-ai-talk-local-smoke-archive": "node scripts/create-ai-talk-local-smoke-archive.js",
    "update-packaged-runtime-smoke-report": "node scripts/update-packaged-runtime-smoke-report.js",
    "validate-packaged-runtime-smoke-report": "node scripts/validate-packaged-runtime-smoke-report.js",
    "create-release-evidence-archive-manifest": "node scripts/create-release-evidence-archive-manifest.js",
    "create-signed-release-closure-report": "node scripts/create-signed-release-closure-report.js",
    "create-macos-release-evidence": "node scripts/create-macos-release-evidence.js",
    "create-macos-release-evidence-archive": "node scripts/create-macos-release-evidence-archive.js",
    "create-rc-upgrade-smoke-report": "node scripts/create-rc-upgrade-smoke-report.js",
    "validate-rc-upgrade-smoke-report": "node scripts/validate-rc-upgrade-smoke-report.js",
    "validate:plugin": "node scripts/validate-plugin-package.js",
    "create-openpet-plugin": "node scripts/create-openpet-plugin.js",
    "create-plugin-author-rehearsal": "node scripts/create-plugin-author-rehearsal.js",
    "create-plugin-real-world-submission-rehearsal": "node scripts/create-plugin-real-world-submission-rehearsal.js",
    "create-plugin-remote-source-submission-rehearsal": "node scripts/create-plugin-remote-source-submission-rehearsal.js",
    "create-plugin-community-source-submission-evidence": "node scripts/create-plugin-community-source-submission-evidence.js",
    "create-plugin-community-source-discovery-report": "node scripts/create-plugin-community-source-discovery-report.js",
    "create-plugin-community-source-invitation": "node scripts/create-plugin-community-source-invitation-kit.js",
    "create-plugin-community-source-invitation-kit": "node scripts/create-plugin-community-source-invitation-kit.js",
    "create-plugin-community-source-intake-report": "node scripts/create-plugin-community-source-intake-report.js",
    "create-plugin-community-source-evidence-from-intake": "node scripts/create-plugin-community-source-evidence-from-intake.js",
    "create-plugin-cleanup-evidence": "node scripts/create-plugin-cleanup-evidence.js",
    "create-plugin-cleanup-evidence-collector": "node scripts/create-plugin-cleanup-evidence-collector.js",
    "create-plugin-cleanup-evidence-archive-manifest": "node scripts/create-plugin-cleanup-evidence-archive-manifest.js",
    "run-plugin-cleanup-evidence-collector": "node scripts/run-plugin-cleanup-evidence-collector.js",
    "run-packaged-plugin-cleanup-evidence": "node scripts/run-packaged-plugin-cleanup-evidence.js",
    "run-packaged-creator-studio-evidence": "node scripts/run-packaged-creator-studio-evidence.js",
    "run-packaged-creator-studio-ui-e2e": "node scripts/run-packaged-creator-studio-ui-e2e.js",
    "create-plugin-cleanup-evidence-report": "node scripts/create-plugin-cleanup-evidence-report.js",
    "update-plugin-cleanup-evidence-report": "node scripts/update-plugin-cleanup-evidence-report.js",
    "update-packaged-plugin-cleanup-evidence-report": "node scripts/update-packaged-plugin-cleanup-evidence-report.js",
    "validate-plugin-cleanup-evidence-report": "node scripts/validate-plugin-cleanup-evidence-report.js",
    "smoke:ai-provider": "node scripts/run-ai-provider-smoke.js",
    "smoke:creator-studio-provider": "node scripts/run-creator-studio-provider-smoke.js",
    "create-plugin-sandbox-evaluation": "node scripts/create-plugin-sandbox-evaluation.js",
    "create-plugin-submission-report": "node scripts/create-plugin-submission-report.js",
    "create-plugin-submission-pr": "node scripts/create-plugin-submission-pr.js",
    "create-plugin-submission-bundle": "node scripts/create-plugin-submission-bundle.js",
    "validate-plugin-submission-bundle": "node scripts/validate-plugin-submission-bundle.js",
    "create-plugin-maintainer-approval": "node scripts/create-plugin-maintainer-approval.js",
    "validate-plugin-maintainer-approval": "node scripts/validate-plugin-maintainer-approval.js",
    "generate-sprites": "node scripts/generate-sprites.js",
    "check:docs-drift": "node scripts/check-docs-drift.js",
    "check:node": "find main.js preload.js control-center-preload.js renderer.js scripts src/main src/shared tests examples -name '*.js' -type f -print0 | xargs -0 -n 1 node --check",
    "typecheck": "tsc --noEmit",
    "check:syntax": "npm run check:node && npm run typecheck && npm run build:control-center",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:core": "node --test \"tests/main/*.test.js\" \"tests/services/*.test.js\" \"tests/shared/*.test.js\" \"tests/pet-pack/*.test.js\" \"tests/plugins/*.test.js\" \"tests/examples/*.test.js\" \"tests/renderer-*.test.js\" \"tests/control-center/*.test.js\"",
    "test:core:all": "npm run test:core && npm run test:control-center",
    "test:tools": "node --test \"tests/scripts/*.test.js\" \"tests/release/*.test.js\"",
    "test:control-center": "node scripts/run-control-center-playwright.js"
  },
  "build": {
    "appId": "com.openpet.desktop-pet",
    "productName": "OpenPet",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "preload.js",
      "control-center-preload.js",
      "cat_anime/**/*",
      "assets/pet-packs/**/*",
      "catalog/**/*",
      "examples/plugins/creator-studio/**/*",
      "dist/control-center/**/*",
      "src/main/**/*",
      "src/shared/**/*",
      "package.json"
    ],
    "asar": true,
    "afterSign": "build/notarize.js",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dengyie",
        "repo": "OpenPet",
        "channel": "latest"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenPet",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
