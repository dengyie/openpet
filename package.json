{
  "name": "openpet",
  "version": "1.0.1-rc.1",
  "description": "OpenPet Electron desktop pet platform with Control Center, AI, plugins, and local APIs.",
  "author": "OpenPet contributors",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:control-center && electron .",
    "dev:control-center": "vite --config src/control-center/vite.config.js --host 127.0.0.1",
    "build:control-center": "vite build --config src/control-center/vite.config.js",
    "pack": "npm run build:control-center && electron-builder --dir",
    "dist": "npm run build:control-center && electron-builder",
    "generate-icons": "node scripts/generate-icons.js",
    "prepare-windows-release-assets": "node scripts/prepare-windows-release-assets.js",
    "create-windows-smoke-report": "node scripts/create-windows-smoke-report.js",
    "create-windows-smoke-runbook": "node scripts/create-windows-smoke-runbook.js",
    "create-windows-smoke-collector": "node scripts/create-windows-smoke-collector.js",
    "create-windows-smoke-evidence-summary": "node scripts/create-windows-smoke-evidence-summary.js",
    "create-windows-smoke-archive-manifest": "node scripts/create-windows-smoke-archive-manifest.js",
    "update-windows-smoke-report": "node scripts/update-windows-smoke-report.js",
    "validate-windows-smoke-report": "node scripts/validate-windows-smoke-report.js",
    "validate-windows-smoke-evidence-bundle": "node scripts/validate-windows-smoke-evidence-bundle.js",
    "create-desktop-picker-smoke-report": "node scripts/create-desktop-picker-smoke-report.js",
    "create-desktop-picker-smoke-runbook": "node scripts/create-desktop-picker-smoke-runbook.js",
    "update-desktop-picker-smoke-report": "node scripts/update-desktop-picker-smoke-report.js",
    "validate-desktop-picker-smoke-report": "node scripts/validate-desktop-picker-smoke-report.js",
    "generate-sprites": "node scripts/generate-sprites.js",
    "check:node": "find main.js preload.js control-center-preload.js renderer.js scripts src/main src/shared tests -name '*.js' -type f -print0 | xargs -0 -n 1 node --check",
    "check:syntax": "npm run check:node && npm run build:control-center",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:control-center": "playwright test"
  },
  "build": {
    "appId": "com.openpet.desktop-pet",
    "productName": "OpenPet",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "preload.js",
      "control-center-preload.js",
      "cat_anime/**/*",
      "catalog/**/*",
      "dist/control-center/**/*",
      "src/main/**/*",
      "src/shared/**/*",
      "package.json"
    ],
    "asar": true,
    "afterSign": "build/notarize.js",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dengyie",
        "repo": "OpenPet",
        "channel": "latest"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenPet",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "vite": "^8.0.16"
  }
}
