{
  "id": "openpet.agent-awareness",
  "name": "Agent Awareness",
  "version": "0.1.0",
  "profile": "runtime",
  "description": "Reflect local AI coding-agent activity through OpenPet pet status, speech, and a local dashboard.",
  "permissions": ["pet:say", "pet:event"],
  "entries": {
    "commands": [
      { "id": "install-codex-hooks", "title": "Prepare Codex Hook Instructions", "command": "node ./commands/install-codex-hooks.js", "cwd": "." },
      { "id": "uninstall-codex-hooks", "title": "Prepare Codex Hook Removal", "command": "node ./commands/uninstall-codex-hooks.js", "cwd": "." },
      { "id": "doctor", "title": "Check Agent Awareness Setup", "command": "node ./commands/doctor.js", "cwd": "." }
    ],
    "services": [
      {
        "id": "agent-awareness",
        "title": "Agent Awareness Service",
        "command": "node ./service/agent-awareness-service.js",
        "cwd": ".",
        "health": { "type": "http", "url": "http://127.0.0.1:8795/health" }
      }
    ],
    "dashboards": [
      { "id": "main", "title": "Agent Awareness", "url": "http://127.0.0.1:8795" }
    ]
  },
  "manifest": {
    "adapters": ["codex"],
    "dataLocations": [
      { "path": "OPENPET_DATA_DIR/sessions.json", "description": "Sanitized agent session status history." },
      { "path": "OPENPET_DATA_DIR/codex-hooks.manual.md", "description": "Manual Codex hook setup instructions generated by explicit command." }
    ],
    "privacy": {
      "captures": ["session id hash", "status", "short sanitized message", "cwd basename", "timestamp"],
      "doesNotCapture": ["raw prompt", "tool input", "terminal transcript", "stdout", "stderr", "API keys", "full local paths"]
    }
  },
  "assets": ["web/dashboard/index.html", "web/dashboard/dashboard.js", "web/dashboard/styles.css"]
}
